{
  "name": "lt-quote",
  "description": "引言展示：大引号+引用文字+作者，居中淡入",
  "position": {
    "bottom": "120px",
    "left": "50%",
    "transform": "translateX(-50%)"
  },
  "animation": {
    "enter": {
      "type": "fadeIn",
      "duration": 0.8,
      "delay": 1,
      "easing": "ease-out"
    },
    "exit": {
      "type": "fadeOut",
      "duration": 0.4,
      "easing": "ease-in"
    }
  },
  "layout": {
    "quoteMark": {
      "fontSize": "80px",
      "color": "#6366F1",
      "opacity": 0.3,
      "lineHeight": 0.5
    },
    "text": {
      "fontSize": "22px",
      "fontStyle": "italic",
      "color": "#ffffff"
    },
    "author": {
      "fontSize": "14px",
      "color": "#94a3b8"
    }
  }
}