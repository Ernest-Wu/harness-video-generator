{
  "name": "modern-minimal",
  "description": "深色背景、大字留白、极简排版",
  "theme": {
    "background": "#0A0A0A",
    "primaryText": "#FFFFFF",
    "secondaryText": "#A0A0A0",
    "accent": "#6366F1"
  },
  "typography": {
    "fontFamily": "Noto Sans SC",
    "titleSize": 72,
    "bodySize": 48,
    "lineHeight": 1.6
  },
  "layouts": {
    "9:16": {
      "aspectRatio": "9/16",
      "safeArea": { "top": 100, "bottom": 100, "left": 60, "right": 60 },
      "contentAlignment": "center",
      "titleSize": 72,
      "bodySize": 48
    },
    "16:9": {
      "aspectRatio": "16/9",
      "safeArea": { "top": 80, "bottom": 80, "left": 120, "right": 120 },
      "contentAlignment": "center",
      "titleSize": 64,
      "bodySize": 36
    },
    "4:5": {
      "aspectRatio": "4/5",
      "safeArea": { "top": 80, "bottom": 80, "left": 80, "right": 80 },
      "contentAlignment": "center",
      "titleSize": 68,
      "bodySize": 42
    }
  },
  "useCases": ["专业分析", "知识干货", "深度叙事"]
}